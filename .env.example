# Copy to .env and fill in real values.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/routineguy"

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# Discord OAuth app credentials (discord.com/developers/applications)
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# Discord BOT token (same app → Bot tab → Reset Token). NOT the OAuth secret.
# The bot must be invited to the server and able to post in the target channel.
DISCORD_BOT_TOKEN=""

# Shared secret the nightly cron sends as `Authorization: Bearer <CRON_SECRET>`
# to POST /api/cron/post. Generate any long random string.
CRON_SECRET=""

# --- In-app AI assistant (Stage 3) -----------------------------------------
# Which LLM backend runs the dashboard chat: "ollama" (local dev, default) or
# "gemini" (hosted). The MCP connector (/api/mcp) and GPT Actions (/api/gpt)
# don't use these — there the user's own AI client pays for inference.
AI_CHAT_PROVIDER="ollama"
# Ollama: install from ollama.com, then `ollama pull qwen2.5:1.5b-instruct`
# (or a stronger tool-caller like qwen2.5:7b-instruct if the machine allows).
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5:1.5b-instruct"
# Gemini (aistudio.google.com API key) — only needed when AI_CHAT_PROVIDER=gemini.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
