# Production environment for docker-compose.prod.yml.
# Copy to .env on the server and fill in real values. NEVER commit the real .env.
#
#   cp .env.prod.example .env
#
# Generate the three secrets below with:
#   openssl rand -base64 32

# --- Domain / TLS -----------------------------------------------------------
# The public hostname you point at this VM (an A record → the VM's public IP).
# Used by Caddy (for the cert) AND to build AUTH_URL=https://$DOMAIN.
DOMAIN="relay.labibkarim.com"
# Optional: email the certificate authority uses for expiry notices.
ACME_EMAIL=""

# --- Database ---------------------------------------------------------------
# Strong, random. Must match the password embedded in DATABASE_URL below.
POSTGRES_PASSWORD=""
# NOTE: host is the compose service name `db`, NOT localhost. Keep user
# `routine` and db `routineguy` in sync with docker-compose.prod.yml.
DATABASE_URL="postgresql://routine:REPLACE_WITH_POSTGRES_PASSWORD@db:5432/routineguy"

# --- Auth.js (NextAuth) -----------------------------------------------------
AUTH_SECRET=""

# Discord OAuth app credentials (discord.com/developers/applications).
# Register the redirect URL: https://$DOMAIN/api/auth/callback/discord
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# Discord BOT token (same app → Bot tab → Reset Token). NOT the OAuth secret.
# The bot must be invited to the server and able to post in the target channel.
DISCORD_BOT_TOKEN=""

# --- Nightly digest scheduler ----------------------------------------------
# Shared secret the cron sidecar sends as `Authorization: Bearer <CRON_SECRET>`
# to POST /api/cron/post. Any long random string.
CRON_SECRET=""

# --- In-app AI assistant (OPTIONAL) ----------------------------------------
# The dashboard chat is optional. The core product — schedule → nightly Discord
# digest — works with none of this set. Left as-is, the app boots fine and only
# the chat feature is inert until an LLM backend is reachable.
# (The MCP connector /api/[transport] and GPT Actions /api/gpt do NOT use these:
#  there the user's own AI client pays for inference.)
AI_CHAT_PROVIDER="ollama"            # "ollama" (self-hosted) or "gemini" (hosted)
# Ollama: install on the VM, then `ollama pull qwen2.5:1.5b-instruct`.
# NOTE: inside the web container, localhost is the CONTAINER. To reach an Ollama
# running on the VM host, use the host IP (or run Ollama as another compose svc).
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5:1.5b-instruct"
# Gemini (aistudio.google.com API key) — only when AI_CHAT_PROVIDER=gemini.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
